# --- LOCAL DEVELOPMENT (DOCKER) ---
DB_USER=crawler_user
DB_PASSWORD=crawler_pass
DB_HOST=localhost
DB_PORT=5433
DB_NAME=stock_market_crawler_data

# --- CLOUD DEPLOYMENT (SUPABASE / SELF-HOSTED REDIS) ---
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
# REDIS_URL=redis://:[PASSWORD]@[GCE_VM_IP]:6379/0

# Logging
LOG_LEVEL=INFO
# LOG_FORMAT controls the loguru sink: "human" (colored stderr, local dev)
# or "gcp" (newline-delimited JSON on stdout, picked up automatically by
# Cloud Run / GCE COS / Cloud Run Jobs for Cloud Logging ingestion).
LOG_FORMAT=human

# Observability / service identity (attached to every log line and OTel span).
# SERVICE_VERSION should be overridden in CI with the deployed git SHA.
SERVICE_NAME=stock-market-crawler
SERVICE_VERSION=dev
DEPLOYMENT_ENV=development
# GCP_PROJECT_ID falls back to GOOGLE_CLOUD_PROJECT (auto-set on Cloud Run/GCE).
# When set, log entries link to Cloud Trace via fully-qualified trace URIs.
# GCP_PROJECT_ID=

# --- OpenTelemetry tracing (requires `uv sync --extra observability`) ---
# Kill switch — leave false until the SDK extras are installed.
OTEL_ENABLED=false
# Backend: console (debug) | otlp (Tempo/Collector) | gcp (Cloud Trace direct).
OTEL_EXPORTER=console
# 1.0 = trace every request (dev). Use 0.05–0.10 in prod.
OTEL_SAMPLE_RATIO=1.0
# Redis instrumentor adds a span for every broker poll — leave off when Celery
# uses Redis as its broker, or trace volume will explode.
OTEL_INSTRUMENT_REDIS=false
# Standard OTel SDK env vars (read by the SDK, not by core.config):
# OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4317
# OTEL_PYTHON_FASTAPI_EXCLUDED_URLS=/health,/metrics,/docs,/openapi.json,/

# --- CORS (PRODUCTION ONLY) ---
# Comma-separated list of allowed origins when ENV=production.
# Example: ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
ALLOWED_ORIGINS=
