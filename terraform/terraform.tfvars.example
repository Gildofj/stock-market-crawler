# GCP Project Configuration
project_id   = "your-gcp-project-id"
image_name   = "gcr.io/your-gcp-project-id/stock-market-crawler:latest"

# External Infrastructure (Secrets)
database_url = "postgresql://user:pass@db.supabase.co:6543/postgres"

# Redis Configuration (Self-hosted on GCE)
redis_url      = "redis://:STRONG_PASSWORD_HERE@VM_PUBLIC_IP:6379/0"
redis_password = "STRONG_PASSWORD_HERE"

# API authentication — generated with `openssl rand -base64 32`.
# Must match the API_KEY GitHub Actions secret used by deploy.yml.
api_key = "replace-with-openssl-rand-base64-32"

# Optional Customizations
region          = "us-central1"
allowed_origins = "*"

# Timezone used by Cloud Scheduler (drives the daily RI Cloud Run Job trigger).
scheduler_timezone = "America/Sao_Paulo"

# Cloudflare R2 — leave blank to disable; the app falls back to
# text-only storage in Postgres when these are empty.
#
# S3 credentials (Access Key ID and Secret) are derived automatically
# from the R2_API_TOKEN in runtime.
r2_account_id         = ""
r2_api_token          = ""
r2_bucket_ri_docs     = "ri-docs"
r2_bucket_portfolios  = "portfolios"
r2_ri_public_base_url = ""

#AUTH
api_key = "STRONG KEY"
